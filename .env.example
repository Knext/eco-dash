# Required — API keys (free, email sign-up only)
FRED_API_KEY=
ECOS_API_KEY=

# Optional fallback APIs
ALPHA_VANTAGE_KEY=
PUBLIC_DATA_API_KEY=

# KOSIS (Korean Statistical Information Service) — for KR trade indicators
# 1) Get API key from https://kosis.kr/openapi/ (instant signup, free)
# 2) Find statistical tables at https://kosis.kr → search "수출" or "무역"
#    Pick a table → click "URL 확인" or copy orgId/tblId/itmId/objL1 from URL
# 3) Paste the table params below. Format: query-string with custom flags
#    - yoy=true        compute year-over-year %
#    - scale=1000000   divide values (e.g. KRW to billion)
KOSIS_API_KEY=
KOSIS_KR_EXPORT_PARAMS=
KOSIS_KR_EXPORT_SEMI_PARAMS=
KOSIS_KR_TB_PARAMS=

# Required — CRON_SECRET. Must be >=32 chars and NOT start with "change-me".
# Generate one: openssl rand -hex 32
CRON_SECRET=

# Optional — for Vercel deployment. If set, the app uses Turso instead of local SQLite.
# Get them via: turso db create eco-dash && turso db show eco-dash --url && turso db tokens create eco-dash
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional — defaults shown
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DB_PATH=./data/timeseries.db
DATA_REFRESH_CRON=0 0 * * *
LOG_LEVEL=info
TZ=Asia/Seoul
NEXT_PUBLIC_DEFAULT_THEME=system
