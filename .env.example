# Required — API keys (free, email sign-up only)
FRED_API_KEY=
ECOS_API_KEY=

# Optional fallback APIs
ALPHA_VANTAGE_KEY=
PUBLIC_DATA_API_KEY=

# Required — CRON_SECRET. Must be >=32 chars and NOT start with "change-me".
# Generate one: openssl rand -hex 32
CRON_SECRET=

# Optional — defaults shown
NEXT_PUBLIC_BASE_URL=http://localhost:3000
DB_PATH=./data/timeseries.db
DATA_REFRESH_CRON=0 0 * * *
LOG_LEVEL=info
TZ=Asia/Seoul
NEXT_PUBLIC_DEFAULT_THEME=system
