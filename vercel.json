{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm ci",
  "crons": [
    {
      "path": "/api/cron/fetch",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/evaluate",
      "schedule": "5 0 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/fetch/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/evaluate/route.ts": {
      "maxDuration": 30
    }
  }
}
